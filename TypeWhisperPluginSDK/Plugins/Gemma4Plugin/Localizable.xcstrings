{
  "sourceLanguage": "en",
  "strings": {
    "Download & Load": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laden & Aktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み込み & 有効化"
          }
        }
      }
    },
    "Cancel": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbrechen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセル"
          }
        }
      }
    },
    "Delete cached model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwischengespeichertes Modell löschen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュされたモデルを削除"
          }
        }
      }
    },
    "Download timed out while fetching Gemma 4 from Hugging Face. Please retry. Adding an optional HuggingFace token in this plugin can also increase download rate limits.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Download von Gemma 4 von Hugging Face hat zu lange gedauert. Bitte erneut versuchen. Ein optionaler HuggingFace-Token in diesem Plugin kann die Download-Rate-Limits erhoehen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Hugging FaceからGemma 4のダウンロードが長すぎました。再度試してください。このプラグインでオプションのHuggingFaceトークンを使用すると、ダウンロードレート制限を高めることができます。"
          }
        }
      }
    },
    "Downloading %1$@ stalled at %2$@ because no additional bytes were received for five minutes. Try again. If the issue persists, delete the cached model and download it again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Download von %1$@ ist bei %2$@ stehen geblieben, da fünf Minuten lang keine weiteren Bytes empfangen wurden. Versuche es erneut. Wenn das Problem bestehen bleibt, lösche das zwischengespeicherte Modell und lade es erneut herunter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ のダウンロードは %2$@ で停止し、5 分間新しいバイトを受信しませんでした。もう一度お試しください。問題が続く場合は、キャッシュされたモデルを削除して再度ダウンロードしてください。"
          }
        }
      }
    },
    "Preparing %1$@ timed out after 15 minutes (last download progress: %2$@). The downloaded model was kept; try loading it again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Vorbereitung von %1$@ hat nach 15 Minuten das Zeitlimit erreicht (letzter Downloadfortschritt: %2$@). Das heruntergeladene Modell wurde beibehalten; versuche erneut, es zu laden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ の準備は 15 分後にタイムアウトしました（最後のダウンロード進捗: %2$@）。ダウンロード済みモデルは保持されています。もう一度読み込んでください。"
          }
        }
      }
    },
    "The downloaded Gemma model cache appears incomplete or incompatible. Delete the cached model and download it again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der heruntergeladene Gemma-Modellcache scheint unvollständig oder inkompatibel zu sein. Lösche das zwischengespeicherte Modell und lade es erneut herunter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードされたGemmaモデルキャッシュは不完全または互換性がないようです。キャッシュされたモデルを削除し、再度ダウンロードしてください。"
          }
        }
      }
    },
    "HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFace Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFace トークン"
          }
        }
      }
    },
    "Load a Gemma 4 model in Integrations before using it for prompts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade zuerst ein Gemma-4-Modell in den Integrationen, bevor du es fuer Prompts verwendest."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロンプトでGemma 4モデルを使用する前に、統合からGemma 4モデルをまず読み込みます。"
          }
        }
      }
    },
    "Local LLM powered by Google Gemma 4 on Apple Silicon. No API key required.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokales LLM mit Google Gemma 4 auf Apple Silicon. Kein API-Schlüssel erforderlich."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Silicon上でGoogle Gemma 4を使用したローカルLLM。APIキー不要。"
          }
        }
      }
    },
    "Model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modell"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデル"
          }
        }
      }
    },
    "Invalid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ungültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効なHuggingFaceトークン"
          }
        }
      }
    },
    "Experimental": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Experimentell"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実験的"
          }
        }
      }
    },
    "Experimental. You can try it at your own risk.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Experimentell. Du kannst es auf eigene Gefahr ausprobieren."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実験的です。ご自身の責任で試してみてください。"
          }
        }
      }
    },
    "Valid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なHuggingFaceトークン"
          }
        }
      }
    },
    "Validating token...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Token wird geprüft..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トークンの検証中..."
          }
        }
      }
    },
    "Optional. Increases download rate limits. Free at huggingface.co/settings/tokens": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. Erhoeht Download-Rate-Limits. Kostenlos unter huggingface.co/settings/tokens"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オプション。ダウンロードレート制限を高めます。huggingface.co/settings/tokensで無料で取得可能です。"
          }
        }
      }
    },
    "Remove": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除"
          }
        }
      }
    },
    "Save": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichern"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存"
          }
        }
      }
    },
    "Gemma 4 E2B/E4B 4-bit models are recommended. Larger variants are experimental and may fail depending on hardware.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gemma 4 E2B/E4B 4-bit Modelle sind empfohlen. Groessere Varianten sind experimentell und koennen je nach Hardware fehlschlagen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Gemma 4 E2B/E4B 4-bitモデルが推奨されます。より大きいバリアントは実験的であり、ハードウェアによっては失敗する可能性があります。"
          }
        }
      }
    },
    "Try anyway": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Trotzdem versuchen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "それでも試す"
          }
        }
      }
    },
    "Unload": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効化"
          }
        }
      }
    }
  },
  "version": "1.0"
}
