        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle Ton, Sprachverhalten und Ausgabeform."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "口調、言語動作、出力形式を選択します。"
          }
        }
      }
    },
    "Decide whether this drafts a reply or a full email.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege fest, ob eine Antwort oder eine vollständige E-Mail erstellt wird."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これが返信の下書きであるか、電子メール全体であるかを決定します。"
          }
        }
      }
    },
    "Define the structure for the extracted information.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Definiere die Struktur für die extrahierten Informationen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "抽出した情報の構造を定義します。"
          }
        }
      }
    },
    "Choose how the input should be reformatted.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, wie der Input umformatiert werden soll."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "入力を再フォーマットする方法を選択します。"
          }
        }
      }
    },
    "Describe the job briefly, then add optional tone and output hints.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beschreibe die Aufgabe kurz und ergänze optionale Ton- und Ausgabehinweise."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ジョブを簡単に説明し、オプションのトーンと出力ヒントを追加します。"
          }
        }
      }
    },
    "Temperature is not available for Apple Intelligence.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Temperatur ist für Apple Intelligence nicht verfügbar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence では温度を利用できません。"
          }
        }
      }
    },
    "Uses the temperature saved in this provider's settings.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet die in den Provider-Einstellungen gespeicherte Temperatur."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロバイダーの設定に保存された温度を使用します。"
          }
        }
      }
    },
    "Ignores your saved provider setting and lets the provider use its own default behavior.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignoriert deine gespeicherte Provider-Einstellung und nutzt das Standardverhalten des Providers."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存されたプロバイダー設定を無視し、プロバイダーに独自のデフォルト動作を使用させます。"
          }
        }
      }
    },
    "Uses this value only for this prompt. Gemma 4 supports values from 0.0 to 1.0.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet diesen Wert nur für diesen Prompt. Gemma 4 unterstützt Werte von 0.0 bis 1.0."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この値はこのプロンプトにのみ使用されます。 Gemma 4 は 0.0 から 1.0 までの値をサポートします。"
          }
        }
      }
    },
    "Uses this value only for this prompt and overrides the provider setting.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet diesen Wert nur für diesen Prompt und überschreibt die Provider-Einstellung."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この値はこのプロンプトにのみ使用され、プロバイダー設定をオーバーライドします。"
          }
        }
      }
    },
    "Finalize the visible prompt details first. The raw system prompt and action target live in Advanced.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Finalisiere zuerst die sichtbaren Prompt-Details. Roh-System-Prompt und Action-Ziel liegen unter Erweitert."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず、表示されるプロンプトの詳細を最終決定します。生のシステム プロンプトとアクション ターゲットは、Advanced に存在します。"
          }
        }
      }
    },
