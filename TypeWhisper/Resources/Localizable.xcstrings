    "Auto-unload model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modell automatisch entladen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルの自動アンロード"
          }
        }
      }
    },
    "Automatically extracts facts, preferences and patterns from your transcriptions using an LLM. Memories are injected into prompt context.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Extrahiert automatisch Fakten, Präferenzen und Muster aus deinen Transkriptionen per LLM. Erinnerungen werden als Kontext in Prompts eingefügt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LLMを使用して文字起こしからファクト、好み、パターンを自動抽出します。メモリはプロンプトコンテキストに注入されます。"
          }
        }
      }
    },
    "Automatically format transcribed text based on the target app. Configure the output format per workflow.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkribierten Text automatisch basierend auf der Ziel-App formatieren. Das Ausgabeformat kann pro Workflow konfiguriert werden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターゲットアプリに基づいて文字起こしテキストを自動フォーマットします。ワークフローごとに出力形式を設定してください。"
          }
        }
      }
    },
    "Automatically pauses music and videos while recording and resumes when done. Uses macOS system media controls - may not work with all apps.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausiert automatisch Musik und Videos während der Aufnahme und setzt die Wiedergabe fort, wenn fertig. Verwendet macOS-Systemsteuerung - funktioniert möglicherweise nicht mit allen Apps."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音中に音楽やビデオを自動的に一時停止し、完了時に再開します。macOSのシステムメディアコントロールを使用 - すべてのアプリで動作するとは限りません。"
          }
        }
      }
    },
    "Automatically press Enter after inserting text. In chat apps this sends the message, in editors it adds a new line.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drückt nach dem Einfügen automatisch Enter. In Chat-Apps wird die Nachricht gesendet, in Editoren eine neue Zeile eingefügt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テキスト挿入後に自動的にEnterを押します。チャットアプリではメッセージを送信し、エディタでは改行を追加します。"
          }
        }
      }
    },
    "Automatically unloads local models from memory after inactivity. It reloads when needed. Does not affect cloud engines.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entlädt lokale Modelle nach Inaktivität automatisch aus dem Arbeitsspeicher. Bei Bedarf werden sie neu geladen. Cloud-Engines sind nicht betroffen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非アクティブ時にローカルモデルをメモリから自動的にアンロードします。必要時に再読み込みします。クラウドエンジンには影響しません。"
          }
        }
      }
    },
