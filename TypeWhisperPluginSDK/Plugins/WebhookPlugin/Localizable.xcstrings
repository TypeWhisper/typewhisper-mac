  "strings": {
    "Active for all transcriptions.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv für alle Transkriptionen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての文字起こしに対して有効。"
          }
        }
      }
    },
    "Add a webhook to send transcription data to external services.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge einen Webhook hinzu, um Transkriptionsdaten an externe Dienste zu senden."
