    "Show or hide the transcript window with a keyboard shortcut.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkript-Fenster mit einem Tastenkürzel ein- oder ausblenden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーボードショートカットでテキストウィンドウを表示または非表示にします。"
