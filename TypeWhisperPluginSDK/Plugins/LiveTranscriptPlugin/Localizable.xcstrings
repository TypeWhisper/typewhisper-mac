  "strings": {
    "Auto-open on recording": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatisch bei Aufnahme öffnen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音時に自動で開く"
          }
        }
      }
    },
