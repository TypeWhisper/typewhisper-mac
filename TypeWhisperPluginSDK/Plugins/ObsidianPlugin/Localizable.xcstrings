      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dateiname:"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイル名:"
          }
        }
      }
    },
    "No vault selected": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Vault ausgewählt"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaultが選択されていません"
          }
        }
