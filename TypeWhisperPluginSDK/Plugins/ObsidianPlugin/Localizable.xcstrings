{
  "sourceLanguage": "en",
  "strings": {
    "Add metadata (date, app, language, tags) to each note.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Metadaten (Datum, App, Sprache, Tags) zu jeder Notiz hinzufügen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ノートにメタデータ（日付、アプリ、言語、タグ）を追加します。"
          }
        }
      }
    },
    "Append all transcriptions to a single daily file instead of creating individual notes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Transkriptionen an eine einzelne Tagesdatei anhängen, statt einzelne Notizen zu erstellen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "個別のノートを作成する代わりに、すべての文字起こしを1つのデイリーファイルに追記します。"
          }
        }
      }
    },
    "Auto-Export": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-Export"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動エクスポート"
          }
        }
      }
    },
    "Automatically save every transcription to Obsidian.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Transkription automatisch in Obsidian speichern."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての文字起こしを自動的にObsidianに保存します。"
          }
        }
      }
    },
    "Browse...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsuchen ..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "参照..."
          }
        }
      }
    },
    "Copy Instruction": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anweisung kopieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "指示をコピー"
          }
        }
      }
    },
    "Create a Custom Workflow, paste this into Instruction, and set Action Target to \"Save to Obsidian\".": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle einen eigenen Workflow, füge dies in Anweisung ein und setze das Action-Ziel auf \"Save to Obsidian\"."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カスタムワークフローを作成し、これをインストラクションに貼り付けて、アクションターゲットを「Obsidianに保存」に設定してください。"
          }
        }
      }
    },
    "Daily Note Mode": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tagesnotiz-Modus"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デイリーノートモード"
          }
        }
      }
    },
    "Detected Vaults": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erkannte Vaults"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検出されたVault"
          }
        }
      }
    },
    "File Organization": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dateiorganisation"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイル整理"
          }
        }
      }
    },
