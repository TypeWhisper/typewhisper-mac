{
  "sourceLanguage": "en",
  "strings": {
    "API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキー"
          }
        }
      }
    },
    "API keys are stored securely in the Keychain": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel werden sicher im Schlüsselbund gespeichert"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキーはキーチェーンに安全に保存されます"
          }
        }
      }
    },
    "Connected": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbunden"
