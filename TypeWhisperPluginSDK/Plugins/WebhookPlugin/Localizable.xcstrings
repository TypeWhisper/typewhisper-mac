{
  "sourceLanguage": "en",
  "strings": {
    "Add a webhook to send transcription data to external services.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge einen Webhook hinzu, um Transkriptionsdaten an externe Dienste zu senden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Webhookを追加して、文字起こしデータを外部サービスに送信します。"
          }
        }
      }
    },
    "Add Webhook": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Webhook hinzufügen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Webhookを追加"
          }
        }
      }
    },
    "All transcriptions": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Transkriptionen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての文字起こし"
          }
        }
      }
    },
