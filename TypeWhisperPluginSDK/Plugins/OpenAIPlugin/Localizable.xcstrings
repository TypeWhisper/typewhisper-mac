{
  "sourceLanguage": "en",
  "strings": {
    "API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキー"
          }
        }
      }
    },
    "API keys are stored securely in the Keychain": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel werden sicher im Schlüsselbund gespeichert"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキーはキーチェーンに安全に保存されます"
          }
        }
      }
    },
    "ChatGPT Login": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPT-Login"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログイン"
          }
        }
      }
    },
    "ChatGPT login connected": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPT-Login verbunden"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログイン接続済み"
          }
        }
      }
    },
    "ChatGPT login connected.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPT-Login verbunden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログイン接続済み。"
          }
        }
      }
    },
    "ChatGPT login exposes only the supported ChatGPT/Codex models.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der ChatGPT-Login zeigt nur die unterstuetzten ChatGPT-/Codex-Modelle an."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログインではサポートされているChatGPT/Codexモデルのみが表示されます。"
          }
        }
      }
    },
    "Complete the OpenAI login in your browser. TypeWhisper will finish the connection automatically.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schliessen Sie den OpenAI-Login im Browser ab. TypeWhisper verbindet den Account danach automatisch."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザでOpenAIログインを完了してください。TypeWhisperが自動的に接続を完了します。"
          }
        }
      }
    },
    "Connected plan: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbundener Plan: %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続プラン: %@"
          }
        }
      }
    },
    "Connection Method": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindungsmethode"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Connection Method"
          }
        }
      }
    },
    "GPT-4o models do not support Whisper Translate (translation to English).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "GPT-4o-Modelle unterstützen Whisper Translate (Übersetzung ins Englische) nicht."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GPT-4oモデルはWhisper翻訳（英語への翻訳）をサポートしていません。"
          }
        }
      }
    },
    "Imported your existing Codex login.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bestehender Codex-Login importiert."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のCodexログインをインポートしました。"
