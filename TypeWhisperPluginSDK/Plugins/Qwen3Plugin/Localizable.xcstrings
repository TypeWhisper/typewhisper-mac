{
  "sourceLanguage": "en",
  "strings": {
    "Download & Load": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laden & Aktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み込み & 有効化"
          }
        }
      }
    },
    "Local Qwen3-ASR speech-to-text powered by MLX on Apple Silicon. 30 languages plus Chinese dialect coverage, no API key required.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale Qwen3-ASR-Spracherkennung mit MLX auf Apple Silicon. 30 Sprachen plus chinesische Dialektabdeckung, kein API-Schlüssel nötig."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Silicon用MLXによるローカルQwen3-ASR音声認識。30言語＋中国語方言対応、APIキー不要。"
          }
        }
      }
    },
    "Model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modell"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデル"
          }
        }
      }
    },
    "Quick picks": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnellauswahl"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クイック選択"
          }
        }
      }
    },
    "8 GB pick": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "8-GB-Tipp"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "8-GB-ヒント"
          }
        }
      }
    },
    "Recommended": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Empfohlen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "推奨"
          }
        }
      }
    },
    "32 GB quality": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "32-GB-Qualität"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "32-GB-品質"
          }
        }
      }
    },
    "Fast / 8 GB": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnell / 8 GB"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高速 / 8 GB"
          }
        }
      }
    },
    "Best default": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beste Vorgabe"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最適な設定"
          }
        }
      }
    },
    "Quality / 32 GB": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualität / 32 GB"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "品質 / 32 GB"
          }
        }
      }
    },
    "Smallest download; use when memory matters more than quality.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleinster Download; nutze es, wenn Speicher wichtiger als Qualität ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最小のダウンロード；保存容量が品質より重要である場合に使用。"
          }
        }
      }
    },
    "Slightly more precision than 4-bit with a similar footprint.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas mehr Präzision als 4-bit bei ähnlichem Speicherbedarf."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "4-bitと同等のメモリ使用量で少し正確性が向上。"
          }
        }
      }
    },
    "Fast pick for 8 GB Macs and casual dictation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnelle Wahl für 8-GB-Macs und einfache Diktate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "8-GB-Mac向けの高速選択、または簡単な音声入力に最適。"
          }
        }
      }
    },
    "Higher-precision small model when 0.6B quality matters.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleines Modell mit höherer Präzision, wenn 0.6B-Qualität wichtiger ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "0.6B品質が重要である場合に、より高い精度を持つ小さなモデル。"
          }
        }
      }
    },
    "Unquantized small model; useful for comparison or validation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unquantisiertes kleines Modell; nützlich für Vergleich oder Validierung."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非量子化された小さなモデル；比較や検証に有用。"
          }
        }
      }
    },
    "Smallest 1.7B option; use when 6-bit is too heavy.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleinste 1.7B-Option; nutze sie, wenn 6-bit zu schwer ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最小の1.7Bオプション；6-bitが重すぎる場合に使用。"
          }
        }
      }
    },
    "Middle ground if the default 6-bit model is tight on memory.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mittelweg, wenn das 6-bit-Standardmodell knapp im Speicher wird."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "6-bit標準モデルがメモリ不足になる場合に中間選択。"
          }
        }
      }
    },
    "Best default for most 16 GB+ Macs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beste Vorgabe für die meisten Macs mit 16 GB+."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "16 GB以上のMacのほとんどに最適な設定。"
          }
        }
      }
    },
    "Higher-quality pick for 32 GB+ Macs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualitätswahl für Macs mit 32 GB+."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "32 GB以上のMac向けの品質選択。"
          }
        }
      }
    },
    "Largest unquantized model; use for max-fidelity validation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Größtes unquantisiertes Modell; für Validierung mit maximaler Wiedergabetreue."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最大の非量子化モデル；最大の再生精度を求める検証に最適。"
          }
        }
      }
    },
    "HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFace Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFaceトークン"
          }
        }
      }
    },
    "Invalid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ungültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効なHuggingFace Token"
          }
        }
      }
    },
    "Optional. Increases download rate limits. Free at huggingface.co/settings/tokens": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. Erhöht Download-Rate-Limits. Kostenlos unter huggingface.co/settings/tokens"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オプション。ダウンロード速度制限を解除します。huggingface.co/settings/tokensで無料で取得可能です。"
          }
        }
      }
    },
    "Remove": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除"
          }
        }
      }
    },
    "Save": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichern"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存"
          }
        }
      }
    },
    "Valid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なHuggingFace Token"
          }
        }
      }
    },
    "Validating token...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Token wird geprüft..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tokenの検証中..."
          }
        }
      }
    },
    "Unload": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効化"
          }
        }
      }
    }
  },
  "version": "1.0"
}
