    "TypeWhisper Dev": {
      "comment": "The name of the app in development mode.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "TypeWhisper Dev"
