    },
    "When hidden, the app stays accessible via the Dock icon.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn ausgeblendet, bleibt die App über das Dock-Symbol erreichbar."
