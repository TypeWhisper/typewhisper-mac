{
  "sourceLanguage": "en",
  "strings": {
    "Active for all transcriptions.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv für alle Transkriptionen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのテキスト転写に有効。"
          }
        }
      }
    },
    "Add a script to process transcribed text via shell commands.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge ein Skript hinzu, um transkribierten Text per Shell-Befehl zu verarbeiten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スクリプトを追加して、シェルコマンドで転写テキストを処理します。"
          }
        }
      }
    },
