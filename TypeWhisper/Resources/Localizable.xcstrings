    "Installing %@ %@ will replace an older external plugin bundle (%@) that was kept for another TypeWhisper runtime. Older app versions may stop using that bundle after this replacement.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Installing %1$@ %2$@ will replace an older external plugin bundle (%3$@) that was kept for another TypeWhisper runtime. Older app versions may stop using that bundle after this replacement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@をインストールすると、他のTypeWhisperランタイム用に保持されていた古い外部プラグインバンドル（%@）が置き換えられます。古いアプリバージョンではこの置き換え後にそのバンドルが使用されなくなる場合があります。"
          }
        }
      }
    },
