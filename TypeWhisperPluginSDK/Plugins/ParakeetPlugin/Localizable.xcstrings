{
  "sourceLanguage": "en",
  "strings": {
    "CTC model (~100 MB) - downloads automatically on first use, or:": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CTC-Modell (~100 MB) - wird automatisch beim ersten Gebrauch geladen, oder:"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CTCモデル（約100 MB）- 初回使用時に自動ダウンロード、または:"
          }
        }
      }
    },
    "Download & Load": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laden & Aktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードして読み込み"
          }
        }
      }
    },
    "Download Now": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jetzt herunterladen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今すぐダウンロード"
          }
        }
      }
    },
    "Done": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fertig"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了"
          }
        }
      }
    },
    "Downloading CTC model...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CTC-Modell wird heruntergeladen..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CTCモデルをダウンロード中..."
          }
        }
      }
    },
    "Enable Vocabulary Boosting": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vokabel-Boosting aktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "語彙ブースティングを有効化"
          }
        }
      }
    },
    "Improves recognition of custom terms from your Dictionary using a secondary CTC model.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbessert die Erkennung von Fachbegriffen aus dem Wörterbuch mittels eines sekundären CTC-Modells."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セカンダリCTCモデルを使用して辞書のカスタム用語の認識を向上させます。"
          }
        }
      }
    },
    "Model Version": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modellversion"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルバージョン"
          }
        }
      }
    },
    "NVIDIA Parakeet TDT V2 - extremely fast on Apple Silicon. English only, highest recall. No API key required.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NVIDIA Parakeet TDT V2 - extrem schnell auf Apple Silicon. Nur Englisch, höchster Recall. Kein API-Schlüssel nötig."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "NVIDIA Parakeet TDT V2 - Apple Siliconで超高速。英語のみ、最高の再現率。APIキー不要。"
          }
        }
      }
    },
    "NVIDIA Parakeet TDT - extremely fast on Apple Silicon. 25 European languages, no API key required.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NVIDIA Parakeet TDT - extrem schnell auf Apple Silicon. 25 europäische Sprachen, kein API-Schlüssel nötig."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "NVIDIA Parakeet TDT - Apple Siliconで超高速。25のヨーロッパ言語、APIキー不要。"
          }
        }
      }
    },
    "Ready - %lld terms loaded": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bereit - %lld Begriffe geladen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "準備完了 - %lld用語を読み込み済み"
          }
        }
      }
    },
    "Ready - add terms in Dictionary settings": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bereit - Begriffe in Wörterbuch-Einstellungen hinzufügen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "準備完了 - 辞書設定で用語を追加してください"
          }
        }
      }
    },
    "Retry": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erneut versuchen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再試行"
          }
        }
      }
    },
    "Unload": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アンロード"
          }
        }
      }
    },
    "Vocabulary Boosting": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vokabel-Boosting"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "語彙ブースティング"
          }
        }
      }
    }
  },
  "version": "1.0"
}
