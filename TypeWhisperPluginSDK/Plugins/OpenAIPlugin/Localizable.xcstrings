{
  "sourceLanguage": "en",
  "strings": {
    "API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキー"
          }
        }
      }
    },
    "API keys are stored securely in the Keychain": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel werden sicher im Schlüsselbund gespeichert"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキーはキーチェーンに安全に保存されます"
          }
        }
      }
    },
    "ChatGPT Login": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPT-Login"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログイン"
          }
        }
      }
    },
    "ChatGPT login connected": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPT-Login verbunden"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログインが接続済み"
          }
        }
      }
    },
    "ChatGPT login connected.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPT-Login verbunden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログインが接続済み。"
          }
        }
      }
    },
    "ChatGPT login exposes only the supported ChatGPT/Codex models.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der ChatGPT-Login zeigt nur die unterstuetzten ChatGPT-/Codex-Modelle an."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ChatGPTログインはサポートされているChatGPT/Codexモデルのみを表示します。"
          }
        }
      }
    },
    "Complete the OpenAI login in your browser. TypeWhisper will finish the connection automatically.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schliessen Sie den OpenAI-Login im Browser ab. TypeWhisper verbindet den Account danach automatisch."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザでOpenAIログインを完了してください。TypeWhisperはその後自動でアカウントを接続します。"
          }
        }
      }
    },
    "Connected plan: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbundener Plan: %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続済みプラン: %@"
          }
        }
      }
    },
    "Connection Method": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindungsmethode"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続方法"
          }
        }
      }
    },
    "GPT-4o models do not support Whisper Translate (translation to English).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "GPT-4o-Modelle unterstützen Whisper Translate (Übersetzung ins Englische) nicht."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GPT-4oモデルはWhisper Translate（英語への翻訳）をサポートしていません。"
          }
        }
      }
    },
    "Imported your existing Codex login.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bestehender Codex-Login importiert."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のCodexログインがインポートされました。"
          }
        }
      }
    },
    "Import Codex Login": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex-Login importieren"
