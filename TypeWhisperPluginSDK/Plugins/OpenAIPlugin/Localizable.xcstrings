    "Transcription Model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkriptionsmodell"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声認識モデル"
          }
        }
      }
    },
    "Use your existing ChatGPT Plus/Pro or Codex login for prompt processing. Transcription still requires an API key.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutzen Sie Ihren bestehenden ChatGPT-Plus-/Pro- oder Codex-Login fuer Prompt-Verarbeitung. Fuer Transkription ist weiterhin ein API-Schluessel noetig."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のChatGPT Plus/ProまたはCodexログインを使用してプロンプト処理を行います。音声認識には引き続きAPIキーが必要です。"
          }
        }
      }
    },
    "Using default models. Press Refresh to fetch all available models.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardmodelle werden verwendet. Klicken Sie auf Aktualisieren, um alle verfuegbaren Modelle abzurufen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "標準モデルが使用されます。更新をクリックして利用可能なすべてのモデルを取得してください。"
          }
        }
      }
    },
    "Valid API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gültiger API-Schlüssel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なAPIキー"
          }
        }
      }
    },
    "Validating...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird überprüft ..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認中..."
          }
        }
      }
    },
    "Waiting for OpenAI login...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warte auf OpenAI-Login ..."
          }
        },
        "ja": {
          "stringUnit": {
