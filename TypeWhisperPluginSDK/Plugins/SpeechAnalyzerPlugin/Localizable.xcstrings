{
  "sourceLanguage": "en",
  "strings": {
    "Active: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv: %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブ: %@"
          }
        }
      }
    },
    "Downloading language model...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprachmodell wird heruntergeladen ..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声モデルをダウンロード中..."
          }
        }
      }
    },
    "Loading available languages...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfügbare Sprachen werden geladen ..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用可能な言語を読み込み中..."
          }
        }
      }
    },
    "On-device speech recognition via Apple's Speech framework with streaming support. Select a language model below - only one can be active at a time.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerätebasierte Spracherkennung über Apples Speech-Framework mit Streaming-Unterstützung. Wähle unten ein Sprachmodell - es kann jeweils nur eines aktiv sein."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスベースの音声認識は、AppleのSpeech-Frameworkを使用し、ストリーミングをサポートしています。下から音声モデルを選択してください。一度に1つしかアクティブにできません。"
          }
        }
      }
    },
    "Search languages...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprachen suchen ..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語を検索..."
          }
        }
      }
    },
    "Select": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auswählen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択"
          }
        }
      }
    },
    "Unload": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効化"
          }
        }
      }
    }
  },
  "version": "1.0"
