{
  "sourceLanguage": "en",
  "strings": {
    "Active for all transcriptions.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv für alle Transkriptionen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての文字起こしに対して有効。"
          }
        }
      }
    },
    "Add a script to process transcribed text via shell commands.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge ein Skript hinzu, um transkribierten Text per Shell-Befehl zu verarbeiten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "シェルコマンドで文字起こしテキストを処理するスクリプトを追加します。"
          }
        }
      }
    },
    "Add Example": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beispiel hinzufügen"
          }
