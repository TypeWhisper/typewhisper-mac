{
  "sourceLanguage": "en",
  "strings": {
    "Download & Load": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laden & Aktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードして読み込み"
          }
        }
      }
    },
    "Local Qwen3-ASR speech-to-text powered by MLX on Apple Silicon. 30 languages plus Chinese dialect coverage, no API key required.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale Qwen3-ASR-Spracherkennung mit MLX auf Apple Silicon. 30 Sprachen plus chinesische Dialektabdeckung, kein API-Schlüssel nötig."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Silicon上のMLXで動作するローカルQwen3-ASR音声テキスト変換。30言語と中国語方言をカバー、APIキー不要。"
          }
        }
      }
    },
    "Model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modell"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデル"
          }
        }
      }
    },
    "Quick picks": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnellauswahl"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クイック選択"
          }
        }
      }
    },
    "8 GB pick": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "8-GB-Tipp"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "8 GB向け"
          }
        }
      }
    },
    "Recommended": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Empfohlen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "推奨"
          }
        }
      }
    },
    "32 GB quality": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "32-GB-Qualität"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "32 GB品質"
          }
        }
      }
    },
    "Fast / 8 GB": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnell / 8 GB"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高速 / 8 GB"
          }
        }
      }
    },
    "Best default": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beste Vorgabe"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最良のデフォルト"
          }
        }
      }
    },
    "Quality / 32 GB": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualität / 32 GB"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高品質 / 32 GB"
          }
        }
      }
    },
    "Smallest download; use when memory matters more than quality.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleinster Download; nutze es, wenn Speicher wichtiger als Qualität ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最小ダウンロード。品質よりメモリが重要な場合に使用。"
          }
        }
      }
    },
    "Slightly more precision than 4-bit with a similar footprint.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas mehr Präzision als 4-bit bei ähnlichem Speicherbedarf."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同程度のフットプリントで4ビットより若干高精度。"
          }
        }
      }
    },
    "Fast pick for 8 GB Macs and casual dictation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnelle Wahl für 8-GB-Macs und einfache Diktate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "8 GB Macとカジュアルなディクテーション向けの高速選択。"
          }
        }
      }
    },
    "Higher-precision small model when 0.6B quality matters.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleines Modell mit höherer Präzision, wenn 0.6B-Qualität wichtiger ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "0.6Bの品質が重要な場合の高精度小型モデル。"
          }
        }
      }
    },
    "Unquantized small model; useful for comparison or validation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unquantisiertes kleines Modell; nützlich für Vergleich oder Validierung."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非量子化小型モデル。比較や検証に便利。"
          }
        }
      }
    },
    "Smallest 1.7B option; use when 6-bit is too heavy.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleinste 1.7B-Option; nutze sie, wenn 6-bit zu schwer ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最小の1.7Bオプション。6ビットが重すぎる場合に使用。"
          }
        }
      }
    },
    "Middle ground if the default 6-bit model is tight on memory.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mittelweg, wenn das 6-bit-Standardmodell knapp im Speicher wird."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトの6ビットモデルがメモリに余裕がない場合の中間選択。"
          }
        }
      }
    },
    "Best default for most 16 GB+ Macs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beste Vorgabe für die meisten Macs mit 16 GB+."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ほとんどの16 GB以上のMacに最適なデフォルト。"
          }
        }
      }
    },
    "Higher-quality pick for 32 GB+ Macs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualitätswahl für Macs mit 32 GB+."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "32 GB以上のMac向けの高品質選択。"
          }
        }
      }
    },
    "Largest unquantized model; use for max-fidelity validation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Größtes unquantisiertes Modell; für Validierung mit maximaler Wiedergabetreue."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最大の非量子化モデル。最高精度の検証に使用。"
          }
        }
      }
    },
    "HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFace Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFaceトークン"
          }
        }
      }
    },
    "Invalid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ungültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効なHuggingFaceトークン"
          }
        }
      }
    },
    "Optional. Increases download rate limits. Free at huggingface.co/settings/tokens": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. Erhöht Download-Rate-Limits. Kostenlos unter huggingface.co/settings/tokens"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オプション。ダウンロードレート制限を緩和します。huggingface.co/settings/tokensで無料取得。"
          }
        }
      }
    },
    "Remove": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除"
          }
        }
      }
    },
    "Save": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichern"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存"
          }
        }
      }
    },
    "Valid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なHuggingFaceトークン"
          }
        }
      }
    },
    "Validating token...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Token wird geprüft..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トークンを検証中..."
          }
        }
      }
    },
    "Unload": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アンロード"
          }
        }
      }
