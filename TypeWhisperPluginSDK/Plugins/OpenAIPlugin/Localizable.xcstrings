    "Controls how much thinking time the model spends before answering.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Steuert, wie viel Denkzeit sich das Modell vor der Antwort nimmt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルが回答前にどのくらい考える時間を取るかを制御します。"
          }
        }
      }
    },
