          }
        }
      }
    },
    "No longer available": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht mehr verfügbar"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用できなくなりました"
