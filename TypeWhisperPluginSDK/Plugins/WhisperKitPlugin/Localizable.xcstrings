    "Local speech-to-text using OpenAI Whisper via CoreML. 99+ languages, streaming, translation to English.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale Sprache-zu-Text-Erkennung mit OpenAI Whisper via CoreML. 99+ Sprachen, Streaming, Übersetzung ins Englische."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CoreML経由のOpenAI Whisperを使用したローカル音声テキスト変換。99以上の言語、ストリーミング、英語への翻訳。"
          }
        }
      }
    },
