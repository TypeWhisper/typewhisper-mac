    "This rule is strongest when the app and website match at the same time. If multiple equally specific rules match, the higher priority wins.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Regel ist am stärksten, wenn App und Website gleichzeitig passen. Wenn mehrere gleich spezifische Regeln passen, gewinnt die höhere Priorität."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このルールは、アプリと Web サイトが同時に一致する場合に最も強くなります。複数の同様に具体的なルールが一致する場合、優先順位の高いものが優先されます。"
          }
        }
      }
    },
    " Manual override can force it at any time.": {
