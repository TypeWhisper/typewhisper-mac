{
  "sourceLanguage": "en",
  "strings": {
    "API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキー"
          }
        }
      }
    },
    "API keys are stored securely in the Keychain": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel werden sicher im Schlüsselbund gespeichert"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキーはキーチェーンに安全に保存されます"
          }
        }
      }
    },
    "Copy Instruction": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anweisung kopieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "指示をコピー"
          }
        }
      }
    },
    "Create a Custom Workflow, paste this into Instruction, and set Action Target to \"Create Linear Issue\".": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle einen eigenen Workflow, füge dies in Anweisung ein und setze das Action-Ziel auf \"Create Linear Issue\"."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カスタムワークフローを作成し、これをインストラクションに貼り付けて、アクションターゲットを「Linear Issueを作成」に設定してください。"
          }
        }
      }
    },
    "Create a personal API key at linear.app/settings/api": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle einen persönlichen API-Schlüssel unter linear.app/settings/api"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "linear.app/settings/apiで個人APIキーを作成"
