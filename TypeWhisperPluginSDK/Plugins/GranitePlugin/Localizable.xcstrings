{
  "sourceLanguage": "en",
  "strings": {
    "Download & Load": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laden & Aktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードして読み込み"
          }
        }
      }
    },
    "Local speech-to-text and translation by IBM, powered by MLX on Apple Silicon. 6 languages with bidirectional translation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale Spracherkennung und Uebersetzung von IBM mit MLX auf Apple Silicon. 6 Sprachen mit bidirektionaler Uebersetzung."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "IBMによるローカル音声テキスト変換と翻訳。Apple Silicon上のMLXで動作。6言語の双方向翻訳対応。"
          }
        }
      }
    },
    "Model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modell"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデル"
          }
        }
      }
    },
    "HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFace Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "HuggingFaceトークン"
          }
        }
      }
    },
    "Invalid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ungültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効なHuggingFaceトークン"
          }
        }
      }
    },
    "Optional. Increases download rate limits. Free at huggingface.co/settings/tokens": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. Erhöht Download-Rate-Limits. Kostenlos unter huggingface.co/settings/tokens"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オプション。ダウンロードレート制限を緩和します。huggingface.co/settings/tokensで無料取得。"
          }
        }
      }
    },
    "Remove": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除"
          }
        }
      }
    },
    "Save": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichern"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存"
          }
        }
      }
    },
    "Valid HuggingFace Token": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gültiger HuggingFace-Token"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なHuggingFaceトークン"
          }
        }
      }
    },
    "Validating token...": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Token wird geprüft..."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トークンを検証中..."
          }
        }
      }
    },
    "Unload": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アンロード"
          }
        }
      }
